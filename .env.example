# Jira
JIRA_BASE=https://yourorg.atlassian.net
JIRA_USER=you@example.com
JIRA_TOKEN=your_jira_api_token

# Jira custom fields
PRODUCT_FIELD_ID=customfield_11675
TIME_FIELD_ID=customfield_11609

# Grafana
GRAFANA_HOST=grafana.example.com
GRAFANA_UID=your_dashboard_uid
GRAFANA_SLUG=your-dashboard-slug

# Time window (ms)
PRE_MS=120000
POST_MS=60000

# Webhook auth (optional)
WEBHOOK_SECRET=change_me
